# GreenQuest Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ============================================================================
# SMS CHEF API CONFIGURATION
# ============================================================================
# Required for SMS/OTP functionality
SMS_CHEF_API_KEY=your_sms_chef_api_key_here
DEVICE_ID=your_device_id_here

# ============================================================================
# CLOUDINARY CONFIGURATION
# ============================================================================
# Get these from: https://cloudinary.com/console
# Required for image and file uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================================================
# ONESIGNAL CONFIGURATION
# ============================================================================
# Get this from: https://onesignal.com/
# Required for push notifications
ONESIGNAL_APP_ID=your_onesignal_app_id_here

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Make sure .env is listed in .gitignore (already done)
# 4. Run: flutter pub get
# 5. Run: flutter run
#
# For more information, see: ENVIRONMENT_SETUP.md
