# GreenQuest Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ============================================================================
# SMS CHEF API CONFIGURATION (legacy - kept for reference)
# ============================================================================
SMS_CHEF_API_KEY=your_sms_chef_api_key_here
DEVICE_ID=your_device_id_here

# ============================================================================
# SEMAPHORE API CONFIGURATION
# ============================================================================
# Get this from: https://semaphore.co
# Required for SMS/OTP functionality (server-side only via Vercel)
SEMAPHORE_API_KEY=your_semaphore_api_key_here

# ============================================================================
# VERCEL API BASE URL
# ============================================================================
# The base URL of your Vercel deployment (no trailing slash)
# Used by the Flutter app to call the serverless OTP functions
# Also add this to Vercel Environment Variables dashboard
VERCEL_BASE_URL=https://greenquest-seven.vercel.app
VERCEL_BASE_URL_LOCAL=http://localhost:3000

# ============================================================================
# CLOUDINARY CONFIGURATION
# ============================================================================
# Get these from: https://cloudinary.com/console
# Required for image and file uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================================================
# ONESIGNAL CONFIGURATION
# ============================================================================
# Get this from: https://onesignal.com/
# Required for push notifications
ONESIGNAL_APP_ID=your_onesignal_app_id_here

# Get this from: https://semaphore.com/
# Required for SMS/OTP functionality
SEMAPHORE_API_KEY=your_semaphore_api_key_here

# ============================================================================
# EMAILJS CONFIGURATION (server-side instructor approval/rejection emails)
# ============================================================================
# Sign up at: https://www.emailjs.com/
# 1. Create a Service (e.g., Gmail/Outlook) → copy the Service ID
# 2. Create TWO email templates:
#      - Approval template  (use variables: {{to_name}}, {{to_email}}, {{status}}, {{app_name}})
#      - Rejection template (same variables)
# 3. Copy your Public Key and Private Key from Account > API Keys
# Only needed as Vercel environment variables (never exposed to the Flutter app)
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_APPROVED_ID=your_approved_template_id_here
EMAILJS_TEMPLATE_REJECTED_ID=your_rejected_template_id_here
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_here

# RESEND API KEY
RESEND_API_KEY=your_resend_api_key_here

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Make sure .env is listed in .gitignore (already done)
# 4. Run: flutter pub get
# 5. Run: flutter run
#
# For more information, see: ENVIRONMENT_SETUP.md
