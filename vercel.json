{
  "version": 2,
  "buildCommand": "bash build.sh",
  "devCommand": "npx --yes serve build/web -l $PORT",
  "outputDirectory": "build/web",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/build/web/$1"
    }
  ],
  "build": {
    "env": {
      "NODE_VERSION": "16.x",
      "FLUTTER_VERSION": "3.16.9"
    }
  }
}
